# ============================================================
# SGCN v2 - Variables de Entorno (Backend Django)
# Copia este archivo como .env y completa los valores
# ============================================================

# --- Seguridad ---
SECRET_KEY=cambia_esto_por_una_clave_larga_y_aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de Datos (dejar vacío para usar SQLite en dev) ---
# DATABASE_URL=postgresql://usuario:password@localhost:5432/sgcn_db

# --- CORS (Frontend URL) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Django Axes (protección fuerza bruta) ---
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1
