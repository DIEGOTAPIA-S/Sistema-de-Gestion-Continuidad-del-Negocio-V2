# Configuración del Sistema de Gestión de Continuidad (SGCN)
# Copia este archivo como .env y ajusta los valores según tu entorno.

# --- SEGURIDAD ---
# Genera una clave segura para producción (ej: python -c "import secrets; print(secrets.token_urlsafe(50))")
SECRET_KEY=django-insecure-cambiar-en-produccion

# DEBUG: False en producción
DEBUG=True

# Hosts permitidos (separados por coma)
# Producción: sgcn.tuempresa.com
ALLOWED_HOSTS=localhost,127.0.0.1

# --- CORS ---
# Origen del frontend (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- BASE DE DATOS ---
# Si no se configura, usa SQLite por defecto.
# Para PostgreSQL (Producción):
# DB_NAME=continuidad_db
# DB_USER=django_user
# DB_PASSWORD=password_seguro
# DB_HOST=localhost
# DB_PORT=5432

# --- CORREO (Notificaciones / 2FA) ---
# Si EMAIL_HOST_USER está vacío, los correos se imprimen en consola (Modo Dev).
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=notificaciones@tuempresa.com

# --- ADMINISTRACIÓN ---
# Personaliza la URL del panel de administración
ADMIN_URL=admin/
