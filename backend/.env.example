# ============================================================
# SGCN v2 - Variables de Entorno (Backend Django)
# Copia este archivo como .env y completa los valores
# ============================================================

# --- Seguridad ---
SECRET_KEY=cambia_esto_por_una_clave_larga_y_aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- URL del panel de administración (cámbiala en producción para mayor seguridad) ---
# En desarrollo déjala como 'admin/' para acceder en http://localhost:8000/admin/
# En producción usa algo impredecible, ej: gestion-interna-bc2025/
ADMIN_URL=admin/

# --- Base de Datos ---
# Dejar vacío para usar SQLite en desarrollo
# DB_NAME=sgcn_db
# DB_USER=sgcn_user
# DB_PASSWORD=password_seguro
# DB_HOST=localhost
# DB_PORT=5432

# --- CORS y CSRF (Frontend URL) ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# --- Email corporativo (Microsoft 365) ---
# EMAIL_HOST_USER=notificaciones@tuempresa.com
# EMAIL_HOST_PASSWORD=password_de_la_cuenta
# DEFAULT_FROM_EMAIL=notificaciones@tuempresa.com

# --- Django Axes (protección fuerza bruta) ---
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME=1
